# =====================================================================
# Freelandoo Frontend — .env.example
# Copiar como `.env.local` e preencher.
#
# Regra crítica:
#   - Variáveis SEM o prefixo NEXT_PUBLIC_ são SERVER-ONLY
#     (route handlers, server components). NUNCA vão pro bundle.
#   - Variáveis COM o prefixo NEXT_PUBLIC_ são embarcadas no bundle JS
#     e ficam visíveis no navegador. NUNCA colocar segredo aí.
# =====================================================================

# ─── Server-only (rotas Next.js → backend Express) ────────────────────
# URL base do backend para os proxies em app/api/* (sem barra no fim).
# Em dev local: http://localhost:3001
# Em prod: https://freelandoo-backend-production.up.railway.app
BACKEND_API_URL=http://localhost:3001

# ─── Client-side (NEXT_PUBLIC_*) ──────────────────────────────────────
# URL pública do backend para chamadas feitas direto do browser
# (sockets, fluxos legados sem proxy). Mesmo host do BACKEND_API_URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Socket.io / realtime. Se vazio, cai no NEXT_PUBLIC_BACKEND_URL.
NEXT_PUBLIC_REALTIME_URL=

# Google OAuth (botão "Entrar com Google"). Client ID público.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google AdSense — slot ID dos blocos <ContentAd /> (após aprovação).
# Deixar vazio em dev faz os blocos não renderizarem.
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=
